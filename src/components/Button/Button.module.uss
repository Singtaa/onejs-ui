/* On the native UI Toolkit Button. Our class sits on the same element as
   .unity-button / .unity-text-element, so at equal specificity our rules win by
   load order (the default theme's button-state rules were also lowered to
   single-class specificity). */
.button {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    -unity-text-align: middle-center;
    white-space: nowrap;

    margin-top: 0;
    margin-bottom: 0;
    margin-left: 0;
    margin-right: 0;

    padding-top: var(--ojs-space-2);
    padding-bottom: var(--ojs-space-2);
    padding-left: var(--ojs-space-4);
    padding-right: var(--ojs-space-4);

    border-radius: var(--ojs-radius-md);

    /* Constant-width transparent border so the focus ring never shifts layout. */
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-color: rgba(0, 0, 0, 0);
    border-bottom-color: rgba(0, 0, 0, 0);
    border-left-color: rgba(0, 0, 0, 0);
    border-right-color: rgba(0, 0, 0, 0);

    background-color: var(--ojs-primary);
    color: var(--ojs-on-primary);
    font-size: var(--ojs-font-size-md);

    /* Decoration slots: a theme can dress the filled button in a 9-slice frame
       purely through tokens. No-op by default; outlined/ghost intents clear it. */
    background-image: var(--ojs-button-image, none);
    -unity-slice-left: var(--ojs-button-slice, 0);
    -unity-slice-right: var(--ojs-button-slice, 0);
    -unity-slice-top: var(--ojs-button-slice, 0);
    -unity-slice-bottom: var(--ojs-button-slice, 0);
    -unity-slice-scale: var(--ojs-button-slice-scale, 1px);

    transition-property: background-color;
    transition-duration: var(--ojs-motion-fast);
    transition-timing-function: var(--ojs-ease);
}

.button:hover {
    background-color: var(--ojs-primary-hover);
    background-image: var(--ojs-button-image-hover, none);
}

.button:active {
    background-color: var(--ojs-primary-hover);
    background-image: var(--ojs-button-image-active, none);
}

/* Focus ring is class-driven by the focus-visible manager. No `:focus` rule:
   UI Toolkit's :focus doesn't reliably paint on navigation focus and can stick
   after programmatic/pointer focus, which left artifacts. */
.button.focus-ring {
    border-top-color: var(--ojs-ring);
    border-bottom-color: var(--ojs-ring);
    border-left-color: var(--ojs-ring);
    border-right-color: var(--ojs-ring);
}

.button:disabled {
    opacity: 0.5;
}

/* Intent: secondary (outlined). Clears any filled-button frame image. */
.secondary {
    background-color: rgba(0, 0, 0, 0);
    background-image: none;
    color: var(--ojs-fg);
    border-top-color: var(--ojs-border);
    border-bottom-color: var(--ojs-border);
    border-left-color: var(--ojs-border);
    border-right-color: var(--ojs-border);
}

.secondary:hover {
    background-color: var(--ojs-overlay-hover);
    background-image: none;
}

.secondary:active {
    background-color: var(--ojs-overlay-hover);
    background-image: none;
}

/* Intent: ghost (text only). Clears any filled-button frame image. */
.ghost {
    background-color: rgba(0, 0, 0, 0);
    background-image: none;
    color: var(--ojs-fg);
}

.ghost:hover {
    background-color: var(--ojs-overlay-hover);
    background-image: none;
}

.ghost:active {
    background-color: var(--ojs-overlay-hover);
    background-image: none;
}

/* Intent: danger */
.danger {
    background-color: var(--ojs-danger);
    color: var(--ojs-on-danger);
}

.danger:hover {
    background-color: var(--ojs-danger);
}

.danger:active {
    background-color: var(--ojs-danger);
}

/* Sizes */
.sm {
    padding-top: var(--ojs-space-1);
    padding-bottom: var(--ojs-space-1);
    padding-left: var(--ojs-space-3);
    padding-right: var(--ojs-space-3);
    font-size: var(--ojs-font-size-sm);
}

.lg {
    padding-top: var(--ojs-space-3);
    padding-bottom: var(--ojs-space-3);
    padding-left: var(--ojs-space-6);
    padding-right: var(--ojs-space-6);
    font-size: var(--ojs-font-size-lg);
}
